# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pizza-app

# Node Environment
NODE_ENV=development

# Server Port
PORT=5000

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# JWT Secret (change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email Configuration (Gmail SMTP)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Email service provider (gmail, sendgrid, etc)
EMAIL_SERVICE=gmail

# Admin Email
ADMIN_EMAIL=admin@pizzaapp.com

# Verification Email Expiry (in hours)
EMAIL_VERIFICATION_EXPIRY=24

# Password Reset Expiry (in hours)
PASSWORD_RESET_EXPIRY=1
